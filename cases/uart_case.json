{
  "case_name": "UART Loopback Test",
  "description": "UART serial communication loopback test",
  "module": "uart",
  "precheck": true,
  "required_interfaces": {
    "uart": {
      "select": "auto",
      "required": true
    }
  },
  "functions": [
    {
      "name": "test_uart",
      "params": {
        "port": "${interfaces.uart}",
        "baudrate": 115200,
        "loopback": false
      },
      "enabled": true
    }
  ],
  "execution": "sequential",
  "timeout": 30,
  "retry": 1,
  "retry_interval": 2
}
